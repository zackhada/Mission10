@model Bookstore.Models.Cart
@{
    ViewData["Title"] = "Shopping Cart";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index", "Home");
    var justAdded = TempData["AddedToCart"] as string;
}

<h2>Your Shopping Cart</h2>

@if (justAdded == "true")
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Item added!</strong> Your cart has been updated.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">
        Your cart is empty. <a asp-controller="Home" asp-action="Index">Start shopping!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th class="text-end">Price</th>
                    <th class="text-center">Quantity</th>
                    <th class="text-end">Subtotal</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            @item.Book.Title
                            <span class="badge bg-secondary ms-1"
                                  data-bs-toggle="tooltip"
                                  data-bs-placement="top"
                                  title="ISBN: @item.Book.Isbn">
                                @item.Book.Category
                            </span>
                        </td>
                        <td>@item.Book.Author</td>
                        <td class="text-end">$@item.Book.Price.ToString("F2")</td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">@item.Quantity</span>
                        </td>
                        <td class="text-end fw-bold">$@item.Subtotal.ToString("F2")</td>
                        <td class="text-center">
                            <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                <input type="hidden" name="bookId" value="@item.Book.BookId" />
                                <button type="submit" class="btn btn-danger btn-sm"
                                        data-bs-toggle="tooltip"
                                        data-bs-placement="top"
                                        title="Remove @item.Book.Title from cart">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-success">
                    <td colspan="3"></td>
                    <td class="text-center fw-bold">
                        <span class="badge bg-success rounded-pill fs-6">@Model.TotalItems item(s)</span>
                    </td>
                    <td class="text-end fw-bold fs-5">$@Model.Total.ToString("F2")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<div class="mt-3">
    <a href="@returnUrl" class="btn btn-outline-primary">
        &larr; Continue Shopping
    </a>
</div>
